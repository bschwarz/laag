{
  "name": "laag",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "resolutions": {
    "brace-expansion": "^2.0.0",
    "js-yaml": "^6.0.0",
    "flat-cache": "^6.1.20",
    "flatted": "^3.4.2"
  },
  "overrides": {
    "flat-cache": "^6.1.20",
    "flatted": "^3.4.2"
  },
  "scripts": {
    "build": "bun run scripts/build-workspace.ts",
    "build:watch": "bun run scripts/build-workspace.ts --watch",
    "build:core": "bun run scripts/build-workspace.ts --package=@laag/core",
    "build:openapi": "bun run scripts/build-workspace.ts --package=@laag/openapi",
    "build:raml": "bun run scripts/build-workspace.ts --package=@laag/raml",
    "build:smithy": "bun run scripts/build-workspace.ts --package=@laag/smithy",
    "build:clean": "bun run clean && bun run build",
    "build:list": "bun run scripts/build-workspace.ts --list",
    "test": "bun test --recursive",
    "test:watch": "bun test --watch --recursive",
    "lint": "eslint packages/*/src/**/*.ts packages/*/__tests__/**/*.ts",
    "lint:fix": "eslint packages/*/src/**/*.ts packages/*/__tests__/**/*.ts --fix",
    "format": "prettier --write packages/*/src/**/*.ts packages/*/__tests__/**/*.ts *.md packages/*/README.md",
    "format:check": "prettier --check packages/*/src/**/*.ts packages/*/__tests__/**/*.ts *.md packages/*/README.md",
    "type-check": "tsc --noEmit",
    "type-check:all": "bun run --filter='*' type-check",
    "quality": "bun run type-check && bun run lint && bun run format:check",
    "quality:fix": "bun run type-check && bun run lint:fix && bun run format",
    "clean": "bun run --filter='*' clean && rm -rf packages/*/dist",
    "dev": "bun run build:watch",
    "dev:package": "bun run scripts/build-workspace.ts --watch --package",
    "validate:workflows": "bun run scripts/validate-workflows.ts",
    "ci:local": "bun run quality && bun test && bun run build",
    "docs": "typedoc",
    "docs:serve": "bun run docs && cd docs/api && python3 -m http.server 8080",
    "docs:clean": "rm -rf docs/api",
    "release": "bun run scripts/release.ts",
    "release:dry": "bun run scripts/release.ts --dry-run",
    "release:patch": "echo 'Use individual package release scripts instead, e.g.: bun run release:core:patch'",
    "release:minor": "echo 'Use individual package release scripts instead, e.g.: bun run release:core:minor'",
    "release:major": "echo 'Use individual package release scripts instead, e.g.: bun run release:core:major'",
    "release:beta": "echo 'Use individual package release scripts instead, e.g.: bun run release:core:patch --tag=beta'",
    "release:alpha": "echo 'Use individual package release scripts instead, e.g.: bun run release:core:patch --tag=alpha'",
    "prerelease": "bun run quality && bun test && bun run build",
    "release:openapi": "bun run scripts/release-package.ts @laag/openapi",
    "release:openapi:patch": "bun run scripts/release-package.ts @laag/openapi --patch",
    "release:openapi:minor": "bun run scripts/release-package.ts @laag/openapi --minor",
    "release:openapi:major": "bun run scripts/release-package.ts @laag/openapi --major",
    "release:core": "bun run scripts/release-package.ts @laag/core",
    "release:core:patch": "bun run scripts/release-package.ts @laag/core --patch",
    "release:core:minor": "bun run scripts/release-package.ts @laag/core --minor",
    "release:core:major": "bun run scripts/release-package.ts @laag/core --major",
    "release:raml": "bun run scripts/release-package.ts @laag/raml",
    "release:raml:patch": "bun run scripts/release-package.ts @laag/raml --patch",
    "release:raml:minor": "bun run scripts/release-package.ts @laag/raml --minor",
    "release:raml:major": "bun run scripts/release-package.ts @laag/raml --major",
    "release:cli": "bun run scripts/release-package.ts @laag/cli",
    "release:cli:patch": "bun run scripts/release-package.ts @laag/cli --patch",
    "release:cli:minor": "bun run scripts/release-package.ts @laag/cli --minor",
    "release:cli:major": "bun run scripts/release-package.ts @laag/cli --major",
    "release:smithy": "bun run scripts/release-package.ts @laag/smithy",
    "release:smithy:patch": "bun run scripts/release-package.ts @laag/smithy --patch",
    "release:smithy:minor": "bun run scripts/release-package.ts @laag/smithy --minor",
    "release:smithy:major": "bun run scripts/release-package.ts @laag/smithy --major",
    "validate:publishing": "bun run scripts/validate-publishing.ts",
    "pack:all": "bun run --filter='*' pack",
    "pack:dry": "bun run --filter='*' pack --dry-run",
    "test:compatibility": "bun run scripts/test-compatibility.ts",
    "test:compatibility:node": "bun run scripts/test-compatibility.ts --skip-browser --skip-cli",
    "test:compatibility:browser": "bun run scripts/test-compatibility.ts --skip-node --skip-cli",
    "test:compatibility:cli": "bun run scripts/test-compatibility.ts --skip-node --skip-browser",
    "test:integration": "bun run scripts/test-integration.ts",
    "test:integration:workflow": "bun run scripts/test-integration.ts --skip-performance --skip-module-formats",
    "test:integration:performance": "bun run scripts/test-integration.ts --skip-workflow --skip-module-formats",
    "test:integration:modules": "bun run scripts/test-integration.ts --skip-workflow --skip-performance",
    "workspace:list": "find packages -name 'package.json' -not -path '*/dist/*' -exec jq -r '.name + \"@\" + .version + \" (\" + (.scripts.build // \"no build\") + \")\"' {} \\;",
    "workspace:install": "bun install --frozen-lockfile",
    "workspace:update": "bun update",
    "workspace:clean": "bun run --filter='*' clean",
    "workspace:test": "bun test --recursive",
    "workspace:build": "bun run build",
    "workspace:version": "bun run scripts/version-workspace.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "brace-expansion": "^5.0.6",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "minimatch": "^10.2.5",
    "prettier": "^3.8.4",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^6.0.3",
    "yaml": "^2.9.0",
    "esbuild": "^0.28.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "version": "2.0.3"
}
